{
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",            
    "moduleResolution": "NodeNext",  
    "allowSyntheticDefaultImports": true,
    "esModuleInterop": true,
    "allowJs": true,
    "strict": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "outDir": "./dist",
    "rootDir": ".",
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true
  },
  "include": ["src/**/*", "dump_chat.ts"],
  "exclude": ["node_modules", "dist"]
}